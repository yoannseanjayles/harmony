<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Harmony{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 120 120%22><rect width=%22120%22 height=%22120%22 rx=%2228%22 fill=%22%237c3aed%22/><path d=%22M24 82V38h12v16h16V38h12v44H52V66H36v16H24zm48 0V38h12v44H72z%22 fill=%22%23e8e4ff%22/></svg>">
        {% if app.user %}
            <meta name="hm-csrf-api" content="{{ csrf_token('api_mutation') }}">
        {% endif %}
        {% block stylesheets %}
            <link rel="stylesheet" href="/theme/harmony.css">
            <style>
/* ═══════════════════════════════════════════════════════════
   HARMONY  ·  Premium Design System  ·  v2.0
   Inspired by Claude, Google, Linear
   ═══════════════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&display=swap');

/* ── Design Tokens ─────────────────────────────────────── */

:root {
    /* Fonts */
    --hm-font-title:  'DM Sans', 'Inter', system-ui, sans-serif;
    --hm-font-body:   'Inter', system-ui, -apple-system, sans-serif;

    /* Ink */
    --hm-ink:         #f0eef5;
    --hm-ink-soft:    rgba(220, 215, 240, 0.60);
    --hm-ink-ghost:   rgba(200, 195, 225, 0.28);

    /* Backgrounds */
    --hm-bg:          #0a0a12;
    --hm-surface:     rgba(16, 14, 28, 0.92);
    --hm-surface-strong: rgba(22, 20, 40, 0.96);
    --hm-surface-lift:   rgba(32, 28, 56, 0.85);

    /* Borders */
    --hm-border:      rgba(140, 120, 230, 0.10);
    --hm-border-glow: rgba(168, 140, 255, 0.28);

    /* Accents */
    --hm-accent:            #b794f6;
    --hm-accent-primary:    #8b5cf6;
    --hm-accent-primary-deep:#6d28d9;
    --hm-accent-soft:       rgba(139, 92, 246, 0.10);
    --hm-accent-gold:       #f59e0b;
    --hm-accent-gold-soft:  rgba(245, 158, 11, 0.10);

    /* Feedback */
    --hm-danger:  #f87171;
    --hm-success: #34d399;

    /* Elevation */
    --hm-shadow:  0 0 0 1px rgba(140, 120, 230, 0.06),
                  0 4px 16px rgba(0, 0, 0, 0.40),
                  0 16px 48px rgba(0, 0, 0, 0.24);
    --hm-shadow-card: 0 0 0 1px rgba(140, 120, 230, 0.08),
                      0 2px 8px rgba(0, 0, 0, 0.32),
                      0 12px 40px rgba(69, 26, 155, 0.10);
    --hm-glow-accent: 0 0 40px rgba(139, 92, 246, 0.18),
                      0 0 80px rgba(139, 92, 246, 0.06);
    --hm-glow-gold:   0 0 30px rgba(245, 158, 11, 0.14);

    /* Transitions */
    --hm-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --hm-ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ── Reset & Base ──────────────────────────────────────── */

*, *::before, *::after {
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--hm-font-body);
    font-size: 15px;
    color: var(--hm-ink);
    background-color: var(--hm-bg);
    background-image:
        radial-gradient(ellipse 70% 50% at 20% 0%,  rgba(109, 40, 217, 0.12), transparent),
        radial-gradient(ellipse 50% 60% at 80% 100%, rgba(139, 92, 246, 0.04), transparent);
}

a {
    color: inherit;
    text-decoration: none;
}

/* ── Top Navigation Bar ────────────────────────────────── */

.hm-topbar {
    position: sticky;
    top: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 56px;
    padding: 0 24px;
    background: rgba(10, 10, 18, 0.82);
    backdrop-filter: blur(24px) saturate(1.3);
    border-bottom: 1px solid var(--hm-border);
}

.hm-topbar__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--hm-font-title);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--hm-ink);
    letter-spacing: -0.01em;
}

.hm-topbar__brand svg {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
}

.hm-topbar__nav {
    display: flex;
    align-items: center;
    gap: 4px;
}

.hm-topbar__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 0.87rem;
    font-weight: 500;
    color: var(--hm-ink-soft);
    transition: color 0.15s, background 0.15s;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
}

.hm-topbar__link:hover,
.hm-topbar__link--active {
    color: var(--hm-ink);
    background: rgba(139, 92, 246, 0.08);
}

.hm-topbar__right {
    display: flex;
    align-items: center;
    gap: 8px;
}

.hm-topbar__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--hm-accent-primary), var(--hm-accent-primary-deep));
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
}

/* ── Shell ─────────────────────────────────────────────── */

.hm-shell {
    min-height: calc(100vh - 56px);
    display: grid;
    place-items: center;
    padding: 40px 24px;
}

.hm-shell--top {
    align-content: start;
    place-items: start center;
    padding-top: 32px;
}

/* ── Card ──────────────────────────────────────────────── */

.hm-card {
    width: min(100%, 1020px);
    display: grid;
    grid-template-columns: minmax(280px, 1fr) minmax(320px, 460px);
    border: 1px solid var(--hm-border);
    border-radius: 24px;
    overflow: hidden;
    background: var(--hm-surface);
    backdrop-filter: blur(32px) saturate(1.3);
    box-shadow: var(--hm-shadow);
    position: relative;
    animation: hm-card-in 0.6s var(--hm-ease) both;
}

/* subtle rim light on card */
.hm-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 24px;
    padding: 1px;
    background: linear-gradient(145deg,
        rgba(168, 140, 255, 0.20) 0%,
        transparent 40%,
        transparent 60%,
        rgba(245, 158, 11, 0.08) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 1;
}

/* ── Panels ────────────────────────────────────────────── */

.hm-panel {
    padding: 48px 40px;
    position: relative;
}

/* Brand panel */
.hm-panel--brand {
    background:
        radial-gradient(ellipse 80% 60% at 0% 0%,   rgba(109, 40, 217, 0.40), transparent 60%),
        radial-gradient(ellipse 50% 50% at 100% 100%, rgba(139, 92, 246, 0.08), transparent 50%),
        linear-gradient(170deg, rgba(14, 10, 32, 0.96), rgba(8, 6, 20, 0.98));
    overflow: hidden;
}

/* decorative orb */
.hm-panel--brand::before {
    content: '';
    position: absolute;
    bottom: -60px;
    right: -40px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12) 0%, transparent 70%);
    filter: blur(30px);
    pointer-events: none;
}

/* decorative line texture */
.hm-panel--brand::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
        -55deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.008) 40px,
        rgba(255, 255, 255, 0.008) 41px
    );
    pointer-events: none;
}

/* Form panel */
.hm-panel:not(.hm-panel--brand) {
    background: rgba(12, 10, 24, 0.88);
}

/* ── Kicker / Badge Pill ───────────────────────────────── */

.hm-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    font-family: var(--hm-font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--hm-accent);
    background: var(--hm-accent-soft);
    border: 1px solid rgba(139, 92, 246, 0.16);
}

/* ── Titles ────────────────────────────────────────────── */

.hm-brand-title,
.hm-page-title {
    margin: 20px 0 14px;
    font-family: var(--hm-font-title);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
}

.hm-brand-title {
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    font-style: italic;
    background: linear-gradient(135deg, #f0eef5 0%, #b794f6 50%, var(--hm-accent-gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hm-page-title {
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    color: var(--hm-ink);
}

/* ── Copy ──────────────────────────────────────────────── */

.hm-copy,
.hm-panel--brand p,
.hm-muted {
    color: var(--hm-ink-soft);
    line-height: 1.65;
    font-size: 0.92rem;
    font-weight: 400;
}

/* ── Metrics Grid ──────────────────────────────────────── */

.hm-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 28px;
}

.hm-metric {
    padding: 18px 16px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(139, 92, 246, 0.08);
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
}

.hm-metric::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.25), transparent);
}

.hm-metric:hover {
    border-color: rgba(139, 92, 246, 0.18);
    background: rgba(255, 255, 255, 0.04);
}

.hm-metric strong {
    display: block;
    font-family: var(--hm-font-title);
    font-size: 1.6rem;
    font-weight: 700;
    background: linear-gradient(135deg, #f0eef5, #b794f6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hm-metric span {
    display: block;
    margin-top: 4px;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--hm-ink-ghost);
}

/* ── Badge ─────────────────────────────────────────────── */

.hm-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--hm-accent-soft);
    color: var(--hm-accent);
    font-size: 0.75rem;
    font-weight: 600;
    border: 1px solid rgba(139, 92, 246, 0.14);
    letter-spacing: 0.02em;
}

/* ── Form Wrapper ──────────────────────────────────────── */

.hm-form-wrap {
    background: transparent;
}

/* ── Form ──────────────────────────────────────────────── */

.hm-form {
    display: grid;
    gap: 18px;
    margin-top: 22px;
}

.hm-form-grid {
    display: grid;
    gap: 14px;
}

/* ── Fields ────────────────────────────────────────────── */

.hm-field {
    position: relative;
}

.hm-field label {
    display: inline-block;
    margin-bottom: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--hm-ink-soft);
}

.hm-field input,
.hm-field select {
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid var(--hm-border);
    background: rgba(255, 255, 255, 0.03);
    color: var(--hm-ink);
    font-family: var(--hm-font-body);
    font-size: 0.93rem;
    font-weight: 400;
    transition:
        border-color 0.2s ease,
        box-shadow   0.2s ease,
        background   0.2s ease;
    appearance: none;
    -webkit-appearance: none;
}

.hm-field input::placeholder {
    color: var(--hm-ink-ghost);
}

.hm-field input:hover,
.hm-field select:hover {
    border-color: rgba(139, 92, 246, 0.22);
    background: rgba(255, 255, 255, 0.04);
}

.hm-field input:focus,
.hm-field select:focus {
    outline: none;
    border-color: var(--hm-accent-primary);
    background: rgba(139, 92, 246, 0.04);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.12);
}

.hm-field ul {
    margin: 8px 0 0;
    padding-left: 16px;
    list-style: none;
    font-size: 0.83rem;
    color: var(--hm-danger);
}

.hm-field ul li::before {
    content: '⚠ ';
    font-size: 0.75em;
}

/* ── Alerts ────────────────────────────────────────────── */

.hm-alert {
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid transparent;
    line-height: 1.55;
    font-size: 0.9rem;
    display: flex;
    gap: 10px;
    align-items: flex-start;
}

.hm-alert--danger {
    color: var(--hm-danger);
    background: rgba(248, 113, 113, 0.06);
    border-color: rgba(248, 113, 113, 0.14);
}

.hm-alert--success {
    color: var(--hm-success);
    background: rgba(52, 211, 153, 0.06);
    border-color: rgba(52, 211, 153, 0.14);
}

/* ── Checkbox ──────────────────────────────────────────── */

.hm-check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--hm-ink-soft);
    cursor: pointer;
    user-select: none;
}

.hm-check input[type="checkbox"] {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    accent-color: var(--hm-accent-primary);
    cursor: pointer;
    flex-shrink: 0;
}

/* ── Actions Row ───────────────────────────────────────── */

.hm-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-top: 4px;
}

/* ── Buttons ───────────────────────────────────────────── */

.hm-button,
.hm-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 44px;
    padding: 0 20px;
    border-radius: 12px;
    font-family: var(--hm-font-body);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    border: 0;
    position: relative;
    overflow: hidden;
    transition:
        transform    0.18s var(--hm-ease),
        box-shadow   0.18s ease,
        background   0.18s ease,
        border-color 0.18s ease;
}

/* Primary button */
.hm-button {
    color: #ffffff;
    background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 60%, #6d28d9 100%);
    box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.08) inset,
        0 4px 16px rgba(109, 40, 217, 0.30);
}

/* shimmer sweep on button */
.hm-button::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg,
        transparent 40%,
        rgba(255, 255, 255, 0.10) 50%,
        transparent 60%
    );
    transform: translateX(-100%);
    transition: transform 0.5s ease;
}

.hm-button:hover::after {
    transform: translateX(100%);
}

.hm-button:hover {
    transform: translateY(-1px);
    box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.10) inset,
        0 8px 28px rgba(109, 40, 217, 0.40);
}

.hm-button:active {
    transform: translateY(0) scale(0.99);
}

.hm-button:disabled {
    opacity: 0.5;
    cursor: default;
    transform: none;
}

/* Ghost / outline button */
.hm-link {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--hm-border);
    color: var(--hm-ink-soft);
}

.hm-link:hover {
    transform: translateY(-1px);
    border-color: rgba(139, 92, 246, 0.24);
    background: rgba(139, 92, 246, 0.06);
    color: var(--hm-ink);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14);
}

/* ── Help Text ─────────────────────────────────────────── */

.hm-help {
    margin-top: 16px;
    font-size: 0.84rem;
    color: var(--hm-ink-ghost);
    text-align: center;
    line-height: 1.6;
}

.hm-help a {
    color: var(--hm-accent);
    font-weight: 500;
    transition: color 0.15s;
}

.hm-help a:hover {
    color: var(--hm-ink);
}

/* ── Inline form ───────────────────────────────────────── */

.hm-inline-form {
    margin: 0;
    display: inline;
}

/* ── Dashboard ─────────────────────────────────────────── */

.hm-dashboard {
    width: min(100%, 960px);
    margin: 0 auto;
    padding: 28px;
    border-radius: 20px;
    background: var(--hm-surface);
    border: 1px solid var(--hm-border);
    box-shadow: var(--hm-shadow-card);
    backdrop-filter: blur(20px) saturate(1.2);
    animation: hm-card-in 0.5s var(--hm-ease) both;
}

.hm-dashboard header {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: flex-start;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--hm-border);
}

.hm-dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
}

.hm-dashboard-card {
    padding: 20px;
    border-radius: 14px;
    background: var(--hm-surface-strong);
    border: 1px solid var(--hm-border);
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}

.hm-dashboard-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.25), transparent);
    opacity: 0;
    transition: opacity 0.2s;
}

.hm-dashboard-card:hover {
    border-color: rgba(139, 92, 246, 0.16);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(109, 40, 217, 0.10), 0 2px 8px rgba(0,0,0,0.20);
}

.hm-dashboard-card:hover::before {
    opacity: 1;
}

.hm-dashboard-card strong {
    display: block;
    margin-bottom: 6px;
    font-family: var(--hm-font-title);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--hm-ink);
}

/* ── Dividers ──────────────────────────────────────────── */

hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--hm-border-glow), transparent);
    margin: 20px 0;
}

/* ── Scrollbar ─────────────────────────────────────────── */

::-webkit-scrollbar         { width: 5px; }
::-webkit-scrollbar-track   { background: transparent; }
::-webkit-scrollbar-thumb   { background: rgba(139, 92, 246, 0.18); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: rgba(139, 92, 246, 0.32); }

/* ── Selection ─────────────────────────────────────────── */

::selection {
    background: rgba(139, 92, 246, 0.30);
    color: #fff;
}

/* ── Animations ────────────────────────────────────────── */

@keyframes hm-card-in {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.98);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

@keyframes hm-fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
}

@keyframes hm-shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
}

/* stagger children of form */
.hm-form > *:nth-child(1) { animation: hm-fade-up 0.4s 0.05s both ease; }
.hm-form > *:nth-child(2) { animation: hm-fade-up 0.4s 0.10s both ease; }
.hm-form > *:nth-child(3) { animation: hm-fade-up 0.4s 0.15s both ease; }
.hm-form > *:nth-child(4) { animation: hm-fade-up 0.4s 0.20s both ease; }
.hm-form > *:nth-child(5) { animation: hm-fade-up 0.4s 0.25s both ease; }
.hm-form > *:nth-child(6) { animation: hm-fade-up 0.4s 0.30s both ease; }

/* ── Mobile nav ────────────────────────────────────────── */

.hm-topbar__burger {
    display: none;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--hm-border);
    border-radius: 8px;
    color: var(--hm-ink-soft);
    padding: 5px 10px;
    cursor: pointer;
    font-size: 1.1rem;
    line-height: 1;
    transition: background 0.15s, color 0.15s;
}

.hm-topbar__burger:hover {
    background: var(--hm-accent-soft);
    color: var(--hm-ink);
}

.hm-mobile-nav {
    position: absolute;
    top: 56px;
    left: 0;
    right: 0;
    background: var(--hm-surface-strong);
    border-bottom: 1px solid var(--hm-border);
    backdrop-filter: blur(24px) saturate(1.3);
    padding: 8px 16px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 999;
}

.hm-mobile-nav[hidden] {
    display: none;
}

/* ── Responsive ────────────────────────────────────────── */

@media (max-width: 900px) {
    .hm-topbar__nav {
        display: none;
    }

    .hm-topbar__burger {
        display: inline-flex;
    }

    .hm-panel {
        padding: 32px 24px;
    }

    .hm-panel--brand::before {
        display: none;
    }

    .hm-dashboard header {
        flex-direction: column;
        gap: 14px;
    }

    .hm-metrics {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 720px) {
    .hm-card {
        grid-template-columns: 1fr;
        border-radius: 18px;
    }
}

@media (max-width: 600px) {
    .hm-metrics {
        grid-template-columns: 1fr;
    }

    .hm-dashboard-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 480px) {
    .hm-shell {
        padding: 16px 12px;
    }

    .hm-panel {
        padding: 24px 18px;
    }

    .hm-actions {
        flex-direction: column;
        align-items: stretch;
    }

    .hm-button,
    .hm-link {
        width: 100%;
        justify-content: center;
    }

    .hm-dashboard-grid {
        grid-template-columns: 1fr;
    }
}
            </style>
        {% endblock %}

    </head>
    <body>
        {% block navigation %}
            {% if app.user is defined and app.user %}
                <nav class="hm-topbar" role="navigation" style="position: relative;">
                    <a class="hm-topbar__brand" href="{{ path('app_dashboard') }}">
                        <svg viewBox="0 0 120 120" fill="none"><rect width="120" height="120" rx="28" fill="#7c3aed"/><path d="M24 82V38h12v16h16V38h12v44H52V66H36v16H24zm48 0V38h12v44H72z" fill="#e8e4ff"/></svg>
                        Harmony
                    </a>
                    <div class="hm-topbar__nav">
                        <a class="hm-topbar__link" href="{{ path('app_dashboard') }}">{{ 'navigation.dashboard'|trans }}</a>
                        <a class="hm-topbar__link" href="{{ path('app_project_index') }}">{{ 'navigation.projects'|trans }}</a>
                        <a class="hm-topbar__link" href="{{ path('app_profile') }}">{{ 'navigation.profile'|trans }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="hm-topbar__link" href="{{ path('app_admin_dashboard') }}">{{ 'navigation.admin'|trans }}</a>
                        {% endif %}
                    </div>
                    <div class="hm-topbar__right">
                        <span class="hm-topbar__avatar">{{ app.user.email|first|upper }}</span>
                        <form class="hm-inline-form" method="post" action="{{ path('app_logout') }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button class="hm-topbar__link" type="submit">{{ 'navigation.logout'|trans }}</button>
                        </form>
                        <button class="hm-topbar__burger" type="button" aria-label="Menu" aria-expanded="false" aria-controls="hm-mobile-nav" id="hm-burger-btn">&#9776;</button>
                    </div>

                    <div class="hm-mobile-nav" id="hm-mobile-nav" hidden>
                        <a class="hm-topbar__link" href="{{ path('app_dashboard') }}">{{ 'navigation.dashboard'|trans }}</a>
                        <a class="hm-topbar__link" href="{{ path('app_project_index') }}">{{ 'navigation.projects'|trans }}</a>
                        <a class="hm-topbar__link" href="{{ path('app_profile') }}">{{ 'navigation.profile'|trans }}</a>
                        {% if is_granted('ROLE_ADMIN') %}
                            <a class="hm-topbar__link" href="{{ path('app_admin_dashboard') }}">{{ 'navigation.admin'|trans }}</a>
                        {% endif %}
                    </div>
                </nav>

                <script>
                    (function() {
                        var btn = document.getElementById('hm-burger-btn');
                        var menu = document.getElementById('hm-mobile-nav');
                        if (!btn || !menu) return;
                        btn.addEventListener('click', function(e) {
                            e.stopPropagation();
                            var open = !menu.hidden;
                            menu.hidden = open;
                            btn.setAttribute('aria-expanded', String(!open));
                        });
                        document.addEventListener('click', function(e) {
                            if (!menu.hidden && !menu.contains(e.target) && e.target !== btn) {
                                menu.hidden = true;
                                btn.setAttribute('aria-expanded', 'false');
                            }
                        });
                    })();
                </script>
            {% endif %}
        {% endblock %}

        {% block body %}{% endblock %}

        {% block javascripts %}{% endblock %}
    </body>
</html>
