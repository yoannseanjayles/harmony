<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Harmony{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 120 120%22><rect width=%22120%22 height=%22120%22 rx=%2228%22 fill=%22%237c3aed%22/><path d=%22M24 82V38h12v16h16V38h12v44H52V66H36v16H24zm48 0V38h12v44H72z%22 fill=%22%23e8e4ff%22/></svg>">
        {% if app.user %}
            <meta name="hm-csrf-api" content="{{ csrf_token('api_mutation') }}">
        {% endif %}
        {% block stylesheets %}
            <link rel="stylesheet" href="/theme/harmony.css">
            <style>

                * {
                    box-sizing: border-box;
                }

                body {
                    margin: 0;
                    min-height: 100vh;
                    font-family: var(--hm-font-body);
                    color: var(--hm-ink);
                    background:
                        radial-gradient(circle at 15% 20%, rgba(124, 58, 237, 0.14), transparent 32%),
                        radial-gradient(circle at 85% 80%, rgba(16, 185, 129, 0.10), transparent 28%),
                        var(--hm-bg);
                }

                a {
                    color: inherit;
                }

                .hm-shell {
                    min-height: 100vh;
                    display: grid;
                    place-items: center;
                    padding: 32px 16px;
                }

                .hm-card {
                    width: min(100%, 1080px);
                    display: grid;
                    grid-template-columns: minmax(280px, 1fr) minmax(320px, 480px);
                    border: 1px solid var(--hm-border);
                    border-radius: 30px;
                    overflow: hidden;
                    background: var(--hm-surface);
                    backdrop-filter: blur(16px);
                    box-shadow: var(--hm-shadow);
                }

                .hm-panel {
                    padding: 48px;
                }

                .hm-panel--brand {
                    position: relative;
                    background:
                        linear-gradient(160deg, rgba(124, 58, 237, 0.85), rgba(91, 33, 182, 0.9)),
                        var(--hm-bg);
                    color: var(--hm-ink);
                }

                .hm-panel--brand::after {
                    content: "";
                    position: absolute;
                    inset: auto -40px -60px auto;
                    width: 220px;
                    height: 220px;
                    border-radius: 999px;
                    background: rgba(16, 185, 129, 0.20);
                    filter: blur(10px);
                }

                .hm-kicker {
                    display: inline-flex;
                    align-items: center;
                    gap: 10px;
                    padding: 8px 14px;
                    border-radius: 999px;
                    font-size: 0.78rem;
                    letter-spacing: 0.12em;
                    text-transform: uppercase;
                    background: rgba(255, 255, 255, 0.12);
                }

                .hm-brand-title,
                .hm-page-title {
                    margin: 20px 0 14px;
                    font-family: var(--hm-font-title);
                    line-height: 0.98;
                }

                .hm-brand-title {
                    font-size: clamp(2.8rem, 5vw, 4.8rem);
                }

                .hm-page-title {
                    font-size: clamp(2rem, 4vw, 3rem);
                }

                .hm-copy,
                .hm-panel--brand p,
                .hm-muted {
                    color: var(--hm-ink-soft);
                    line-height: 1.7;
                    font-size: 1rem;
                }

                .hm-panel--brand p,
                .hm-panel--brand .hm-muted {
                    color: rgba(232, 228, 255, 0.72);
                }

                .hm-metrics {
                    display: grid;
                    grid-template-columns: repeat(2, minmax(0, 1fr));
                    gap: 16px;
                    margin-top: 28px;
                }

                .hm-metric {
                    padding: 18px;
                    border-radius: 18px;
                    background: rgba(255, 255, 255, 0.08);
                    border: 1px solid rgba(255, 255, 255, 0.1);
                }

                .hm-metric strong {
                    display: block;
                    font-size: 1.8rem;
                    font-family: var(--hm-font-title);
                }

                .hm-form-wrap {
                    background: rgba(240, 238, 255, 0.04);
                }

                .hm-badge {
                    display: inline-block;
                    padding: 6px 12px;
                    border-radius: 999px;
                    background: var(--hm-accent-soft);
                    color: var(--hm-accent);
                    font-size: 0.82rem;
                    font-weight: 700;
                }

                .hm-form {
                    display: grid;
                    gap: 18px;
                    margin-top: 22px;
                }

                .hm-form-grid {
                    display: grid;
                    gap: 18px;
                }

                .hm-field label {
                    display: inline-block;
                    margin-bottom: 8px;
                    font-weight: 700;
                }

                .hm-field input,
                .hm-field select {
                    width: 100%;
                    padding: 15px 16px;
                    border-radius: 16px;
                    border: 1px solid var(--hm-border);
                    background: rgba(240, 238, 255, 0.06);
                    color: var(--hm-ink);
                    font: inherit;
                    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
                }

                .hm-field input:focus,
                .hm-field select:focus {
                    outline: none;
                    border-color: var(--hm-accent-primary);
                    box-shadow: 0 0 0 4px var(--hm-accent-soft);
                    transform: translateY(-1px);
                }

                .hm-field ul {
                    margin: 10px 0 0;
                    padding-left: 18px;
                    color: var(--hm-danger);
                }

                .hm-alert {
                    padding: 14px 16px;
                    border-radius: 16px;
                    border: 1px solid transparent;
                    line-height: 1.55;
                }

                .hm-alert--danger {
                    color: var(--hm-danger);
                    background: rgba(239, 68, 68, 0.08);
                    border-color: rgba(239, 68, 68, 0.18);
                }

                .hm-alert--success {
                    color: var(--hm-success);
                    background: rgba(16, 185, 129, 0.08);
                    border-color: rgba(16, 185, 129, 0.18);
                }

                .hm-check {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    font-size: 0.95rem;
                    color: var(--hm-ink-soft);
                }

                .hm-check input {
                    width: 18px;
                    height: 18px;
                    accent-color: var(--hm-accent);
                }

                .hm-actions {
                    display: flex;
                    flex-wrap: wrap;
                    gap: 12px;
                    align-items: center;
                    margin-top: 8px;
                }

                .hm-button,
                .hm-link {
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    min-height: 52px;
                    padding: 0 22px;
                    border-radius: 16px;
                    font-weight: 700;
                    text-decoration: none;
                    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
                }

                .hm-button {
                    border: 0;
                    cursor: pointer;
                    color: #fff;
                    background: linear-gradient(135deg, var(--hm-accent-primary), var(--hm-accent-primary-deep));
                    box-shadow: 0 18px 40px rgba(124, 58, 237, 0.30);
                }

                .hm-button:hover,
                .hm-link:hover {
                    transform: translateY(-2px);
                }

                .hm-link {
                    border: 1px solid var(--hm-border);
                    background: var(--hm-surface);
                    color: var(--hm-ink);
                }

                .hm-help {
                    margin-top: 18px;
                    font-size: 0.95rem;
                    color: var(--hm-ink-soft);
                }

                .hm-inline-form {
                    margin: 0;
                }

                .hm-dashboard {
                    width: min(100%, 920px);
                    margin: 0 auto;
                    padding: 24px;
                    border-radius: 30px;
                    background: var(--hm-surface);
                    border: 1px solid var(--hm-border);
                    box-shadow: var(--hm-shadow);
                }

                .hm-dashboard header {
                    display: flex;
                    justify-content: space-between;
                    gap: 16px;
                    align-items: flex-start;
                    margin-bottom: 28px;
                }

                .hm-dashboard-grid {
                    display: grid;
                    grid-template-columns: repeat(3, minmax(0, 1fr));
                    gap: 16px;
                }

                .hm-dashboard-card {
                    padding: 20px;
                    border-radius: 22px;
                    background: var(--hm-surface-strong);
                    border: 1px solid var(--hm-border);
                }

                .hm-dashboard-card strong {
                    display: block;
                    margin-bottom: 10px;
                    font-family: var(--hm-font-title);
                    font-size: 1.5rem;
                }

                @media (max-width: 900px) {
                    .hm-card {
                        grid-template-columns: 1fr;
                    }

                    .hm-panel {
                        padding: 32px 24px;
                    }

                    .hm-dashboard header {
                        flex-direction: column;
                    }

                    .hm-dashboard-grid,
                    .hm-metrics {
                        grid-template-columns: 1fr;
                    }
                }
            </style>
        {% endblock %}

        {% block javascripts %}{% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>
