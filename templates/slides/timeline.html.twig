{#
  Template for slide type "timeline"
  Expected content keys:
    - title  (string, required): slide headline
    - items  (list<object>, required, 2..6): ordered timeline entries
        - year        (string, optional): year or date label shown on the connector
        - label       (string, required): short event title
        - description (string, optional): supporting detail text
#}
<section class="hm-slide hm-slide--timeline" data-slide-type="timeline">
    <div class="hm-slide__inner">
        <h2 class="hm-slide__title">{{ title }}</h2>
        {% if items is defined and items is not empty %}
            <ol class="hm-timeline">
                {% for item in items %}
                    <li class="hm-timeline__item">
                        <div class="hm-timeline__connector" aria-hidden="true">
                            <span class="hm-timeline__dot"></span>
                            {% if not loop.last %}
                                <span class="hm-timeline__line"></span>
                            {% endif %}
                        </div>
                        <div class="hm-timeline__content">
                            {% if item.year is defined and item.year is not empty %}
                                <span class="hm-timeline__year">{{ item.year }}</span>
                            {% endif %}
                            <strong class="hm-timeline__label">{{ item.label }}</strong>
                            {% if item.description is defined and item.description is not empty %}
                                <p class="hm-timeline__description">{{ item.description }}</p>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ol>
        {% endif %}
    </div>
</section>
<style>
    .hm-slide--timeline {
        display: flex;
        align-items: flex-start;
        min-height: 100%;
        background: var(--hm-slide-bg, #0c0c14);
        color: var(--hm-slide-fg, #e8e4ff);
        padding: var(--hm-slide-padding, 3rem 4rem);
    }

    .hm-slide--timeline .hm-slide__inner {
        max-width: 820px;
        width: 100%;
    }

    .hm-slide--timeline .hm-slide__title {
        margin: 0 0 2rem;
        font-family: var(--hm-font-title, Georgia, "Times New Roman", serif);
        font-size: var(--hm-font-size-heading, clamp(1.8rem, 3.5vw, 2.8rem));
        line-height: 1.1;
        color: var(--hm-slide-fg, #e8e4ff);
    }

    .hm-timeline {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .hm-timeline__item {
        display: grid;
        grid-template-columns: 2rem 1fr;
        gap: 0 1rem;
        align-items: start;
    }

    .hm-timeline__connector {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 0.2rem;
    }

    .hm-timeline__dot {
        width: 0.75rem;
        height: 0.75rem;
        border-radius: 50%;
        background: var(--hm-accent-primary, #7c3aed);
        flex-shrink: 0;
    }

    .hm-timeline__line {
        width: 2px;
        flex: 1;
        min-height: 1.5rem;
        background: var(--hm-surface-invert-border, rgba(232, 228, 255, 0.10));
        margin-top: 0.2rem;
        margin-bottom: 0.2rem;
    }

    .hm-timeline__content {
        padding-bottom: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .hm-timeline__year {
        font-size: var(--hm-font-size-label, 0.82rem);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--hm-accent-secondary, #10b981);
        font-family: var(--hm-font-body, "Inter", "Segoe UI", sans-serif);
    }

    .hm-timeline__label {
        font-size: var(--hm-font-size-body, 1rem);
        font-weight: 700;
        line-height: 1.3;
        color: var(--hm-slide-fg, #e8e4ff);
        font-family: var(--hm-font-body, "Inter", "Segoe UI", sans-serif);
    }

    .hm-timeline__description {
        margin: 0;
        font-size: var(--hm-font-size-body, 0.95rem);
        line-height: 1.55;
        color: var(--hm-slide-fg-soft, rgba(232, 228, 255, 0.65));
        font-family: var(--hm-font-body, "Inter", "Segoe UI", sans-serif);
    }
</style>
