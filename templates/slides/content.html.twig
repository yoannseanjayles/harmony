{#
  Template for slide type "content"
  Expected content keys:
    - title (string, required): slide headline
    - body  (string, optional): paragraph text
    - items (list<string>, optional): bullet points
#}
<section class="hm-slide hm-slide--content" data-slide-type="content">
    <div class="hm-slide__inner">
        <h2 class="hm-slide__title">{{ title }}</h2>
        {% if body is defined and body is not empty %}
            <p class="hm-slide__body">{{ body }}</p>
        {% endif %}
        {% if items is defined and items is not empty %}
            <ul class="hm-slide__list">
                {% for item in items %}
                    {% if item is not empty %}
                        <li class="hm-slide__list-item">{{ item }}</li>
                    {% endif %}
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</section>
<style>
    .hm-slide--content {
        display: flex;
        align-items: flex-start;
        min-height: 100%;
        background: var(--hm-slide-bg, var(--hm-surface-strong, #fffdf8));
        color: var(--hm-slide-fg, var(--hm-ink, #173f35));
        padding: var(--hm-slide-padding, 3rem 4rem);
    }

    .hm-slide--content .hm-slide__inner {
        max-width: 820px;
        width: 100%;
    }

    .hm-slide--content .hm-slide__title {
        margin: 0 0 1.25rem;
        font-family: var(--hm-font-title, Georgia, "Times New Roman", serif);
        font-size: var(--hm-font-size-heading, clamp(1.8rem, 3.5vw, 2.8rem));
        line-height: 1.1;
        color: var(--hm-slide-fg, var(--hm-ink, #173f35));
    }

    .hm-slide--content .hm-slide__body {
        margin: 0 0 1.25rem;
        font-size: var(--hm-font-size-body, 1.05rem);
        line-height: 1.7;
        color: var(--hm-slide-fg-soft, var(--hm-ink-soft, #41655d));
        font-family: var(--hm-font-body, "Aptos", "Segoe UI", sans-serif);
    }

    .hm-slide--content .hm-slide__list {
        margin: 0;
        padding-left: 1.4em;
        display: grid;
        gap: 0.55rem;
    }

    .hm-slide--content .hm-slide__list-item {
        font-size: var(--hm-font-size-body, 1.05rem);
        line-height: 1.55;
        color: var(--hm-slide-fg-soft, var(--hm-ink-soft, #41655d));
        font-family: var(--hm-font-body, "Aptos", "Segoe UI", sans-serif);
    }
</style>
