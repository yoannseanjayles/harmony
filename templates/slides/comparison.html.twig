{#
  Template for slide type "comparison"
  Expected content keys:
    - title  (string, required): slide headline
    - left   (object, required): left column data
        - heading   (string, required): column title
        - items     (list<string>, required, 1..6): comparison points
        - highlight (string, optional): call-out badge text
    - right  (object, required): right column data
        - heading   (string, required): column title
        - items     (list<string>, required, 1..6): comparison points
        - highlight (string, optional): call-out badge text
#}
<section class="hm-slide hm-slide--comparison" data-slide-type="comparison">
    <div class="hm-slide__inner">
        <h2 class="hm-slide__title">{{ title }}</h2>
        <div class="hm-comparison">
            <div class="hm-comparison__column hm-comparison__column--left">
                <h3 class="hm-comparison__heading">{{ left.heading }}</h3>
                {% if left.highlight is defined and left.highlight is not empty %}
                    <span class="hm-comparison__highlight hm-comparison__highlight--left">{{ left.highlight }}</span>
                {% endif %}
                {% if left.items is defined and left.items is not empty %}
                    <ul class="hm-comparison__list">
                        {% for item in left.items %}
                            {% if item is not empty %}
                                <li class="hm-comparison__item">{{ item }}</li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
            <div class="hm-comparison__divider" aria-hidden="true"></div>
            <div class="hm-comparison__column hm-comparison__column--right">
                <h3 class="hm-comparison__heading">{{ right.heading }}</h3>
                {% if right.highlight is defined and right.highlight is not empty %}
                    <span class="hm-comparison__highlight hm-comparison__highlight--right">{{ right.highlight }}</span>
                {% endif %}
                {% if right.items is defined and right.items is not empty %}
                    <ul class="hm-comparison__list">
                        {% for item in right.items %}
                            {% if item is not empty %}
                                <li class="hm-comparison__item">{{ item }}</li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>
    </div>
</section>
<style>
    .hm-slide--comparison {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100%;
        background: var(--hm-slide-bg, #0c0c14);
        color: var(--hm-slide-fg, #e8e4ff);
        padding: var(--hm-slide-padding, 3rem 4rem);
    }

    .hm-slide--comparison .hm-slide__inner {
        max-width: 960px;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .hm-slide--comparison .hm-slide__title {
        margin: 0;
        font-family: var(--hm-font-title, Georgia, "Times New Roman", serif);
        font-size: var(--hm-font-size-heading, clamp(1.8rem, 3.5vw, 2.8rem));
        line-height: 1.1;
        color: var(--hm-slide-fg, #e8e4ff);
        text-align: center;
    }

    .hm-comparison {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 0;
        align-items: start;
    }

    .hm-comparison__divider {
        width: 1px;
        min-height: 100%;
        background: var(--hm-surface-invert-border, rgba(232, 228, 255, 0.10));
        margin: 0 2rem;
        align-self: stretch;
    }

    .hm-comparison__column {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 0.5rem;
    }

    .hm-comparison__column--left {
        background: var(--hm-surface-invert-muted, rgba(232, 228, 255, 0.04));
    }

    .hm-comparison__column--right {
        background: rgba(124, 58, 237, 0.08);
    }

    .hm-comparison__heading {
        margin: 0;
        font-family: var(--hm-font-title, Georgia, "Times New Roman", serif);
        font-size: var(--hm-font-size-subheading, clamp(1.2rem, 2vw, 1.6rem));
        line-height: 1.2;
        color: var(--hm-slide-fg, #e8e4ff);
    }

    .hm-comparison__highlight {
        display: inline-block;
        padding: 0.2rem 0.75rem;
        border-radius: 2rem;
        font-size: var(--hm-font-size-label, 0.82rem);
        font-weight: 700;
        font-family: var(--hm-font-body, "Inter", "Segoe UI", sans-serif);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .hm-comparison__highlight--left {
        background: var(--hm-surface-invert-muted, rgba(232, 228, 255, 0.08));
        color: var(--hm-slide-fg-soft, rgba(232, 228, 255, 0.65));
    }

    .hm-comparison__highlight--right {
        background: var(--hm-accent-primary, #7c3aed);
        color: #fff;
    }

    .hm-comparison__list {
        margin: 0;
        padding-left: 1.3em;
        display: grid;
        gap: 0.55rem;
    }

    .hm-comparison__item {
        font-size: var(--hm-font-size-body, 1rem);
        line-height: 1.55;
        color: var(--hm-slide-fg-soft, rgba(232, 228, 255, 0.65));
        font-family: var(--hm-font-body, "Inter", "Segoe UI", sans-serif);
    }
</style>
