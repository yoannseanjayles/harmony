{% extends 'base.html.twig' %}

{% block title %}{{ 'registration.meta_title'|trans }}{% endblock %}

{% block body %}
    <main class="hm-shell">
        <section class="hm-card">
            <aside class="hm-panel hm-panel--brand">
                <span class="hm-kicker">{{ 'brand.kicker'|trans }}</span>
                <h1 class="hm-brand-title">{{ 'brand.title'|trans }}</h1>
                <p>{{ 'registration.brand_copy'|trans }}</p>

                <div class="hm-metrics">
                    <div class="hm-metric">
                        <strong>12+</strong>
                        <span>{{ 'registration.metric.security'|trans }}</span>
                    </div>
                    <div class="hm-metric">
                        <strong>2h</strong>
                        <span>{{ 'registration.metric.session'|trans }}</span>
                    </div>
                    <div class="hm-metric">
                        <strong>100%</strong>
                        <span>{{ 'registration.metric.validation'|trans }}</span>
                    </div>
                    <div class="hm-metric">
                        <strong>1 clic</strong>
                        <span>{{ 'registration.metric.remember'|trans }}</span>
                    </div>
                </div>
            </aside>

            <section class="hm-panel hm-form-wrap">
                <span class="hm-badge">{{ 'registration.badge'|trans }}</span>
                <h2 class="hm-page-title">{{ 'registration.title'|trans }}</h2>
                <p class="hm-copy">{{ 'registration.subtitle'|trans }}</p>

                {% for flash in app.flashes('success') %}
                    <div class="hm-alert hm-alert--success">{{ flash|trans }}</div>
                {% endfor %}

                {{ form_start(registrationForm, { attr: { class: 'hm-form', novalidate: 'novalidate' } }) }}
                    {{ form_errors(registrationForm) }}

                    <div class="hm-form-grid">
                        <div class="hm-field">
                            {{ form_label(registrationForm.email) }}
                            {{ form_widget(registrationForm.email) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="hm-field">
                            {{ form_label(registrationForm.plainPassword.first) }}
                            {{ form_widget(registrationForm.plainPassword.first) }}
                            {{ form_errors(registrationForm.plainPassword.first) }}
                        </div>

                        <div class="hm-field">
                            {{ form_label(registrationForm.plainPassword.second) }}
                            {{ form_widget(registrationForm.plainPassword.second) }}
                            {{ form_errors(registrationForm.plainPassword.second) }}
                        </div>
                    </div>

                    <div class="hm-actions">
                        <button class="hm-button" type="submit">{{ 'registration.submit'|trans }}</button>
                        <a class="hm-link" href="{{ path('app_login') }}">{{ 'registration.login_link'|trans }}</a>
                    </div>
                {{ form_end(registrationForm) }}

                <p class="hm-help">{{ 'registration.help'|trans }}</p>
            </section>
        </section>
    </main>
{% endblock %}
