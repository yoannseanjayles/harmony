{#
  T185 / T186 / T187 / T188 / T189 — Colour & typography customization drawer.
  Provides color pickers, a light/dark toggle, typography selects, and density controls.
  Changes are previewed immediately via JS (T189) and persisted via AJAX (T190).
  Included on project/show.html.twig for non-archived projects.
#}
{% if not project.isArchived %}
{% set tc = project.themeConfig %}

{# Resolve current token values with sensible defaults #}
{% set cur_bg               = tc['--hm-bg']                   ?? '#0c0c14' %}
{% set cur_ink              = tc['--hm-ink']                  ?? '#e8e4ff' %}
{% set cur_accent_primary   = tc['--hm-accent-primary']       ?? '#7c3aed' %}
{% set cur_accent_secondary = tc['--hm-accent-secondary']     ?? '#10b981' %}
{% set cur_slide_bg         = tc['--hm-slide-bg']             ?? '#0c0c14' %}
{% set cur_slide_fg         = tc['--hm-slide-fg']             ?? '#e8e4ff' %}
{% set cur_font_body        = tc['--hm-font-body']            ?? '"Inter", "Segoe UI", system-ui, sans-serif' %}
{% set cur_font_title       = tc['--hm-font-title']           ?? 'Georgia, "Times New Roman", serif' %}
{% set cur_font_weight_bold = tc['--hm-font-weight-bold']     ?? '700' %}
{% set cur_ls_label         = tc['--hm-letter-spacing-label'] ?? '0.12em' %}
{% set cur_ls_tight         = tc['--hm-letter-spacing-tight'] ?? '-0.02em' %}
{% set cur_fs_title         = tc['--hm-font-size-title']      ?? 'clamp(2.4rem, 5vw, 4.2rem)' %}
{% set cur_fs_subtitle      = tc['--hm-font-size-subtitle']   ?? '1.2rem' %}

<section
    class="hm-theme-customizer"
    data-theme-customizer
    data-save-url="{{ path('app_project_theme_tokens', { id: project.id }) }}"
    data-csrf-token="{{ csrf_token('theme_tokens_' ~ project.id) }}"
    data-error-generic="{{ 'project.theme.tokens.error.generic'|trans }}"
    data-label-saving="{{ 'project.theme.tokens.saving'|trans }}"
    data-label-save="{{ 'project.theme.tokens.save'|trans }}"
>
    <header class="hm-theme-customizer__header">
        <span class="hm-badge">{{ 'project.theme.customizer.badge'|trans }}</span>
        <h2 class="hm-theme-customizer__title">{{ 'project.theme.customizer.title'|trans }}</h2>
        <p class="hm-muted">{{ 'project.theme.customizer.subtitle'|trans }}</p>
    </header>

    {# ── T186 — Light / dark toggle ───────────────────────────────────────── #}
    <div class="hm-theme-section">
        <h3 class="hm-theme-section__label">{{ 'project.theme.customizer.section.mode'|trans }}</h3>
        <div class="hm-theme-mode-toggle">
            <button
                class="hm-theme-mode-btn"
                type="button"
                data-theme-mode="dark"
                data-mode-bg="#0c0c14"
                data-mode-ink="#e8e4ff"
                data-mode-slide-bg="#0c0c14"
                data-mode-slide-fg="#e8e4ff"
            >{{ 'project.theme.customizer.mode.dark'|trans }}</button>
            <button
                class="hm-theme-mode-btn"
                type="button"
                data-theme-mode="light"
                data-mode-bg="#ffffff"
                data-mode-ink="#111118"
                data-mode-slide-bg="#ffffff"
                data-mode-slide-fg="#111118"
            >{{ 'project.theme.customizer.mode.light'|trans }}</button>
        </div>
    </div>

    {# ── T185 — Colour pickers ────────────────────────────────────────────── #}
    <div class="hm-theme-section">
        <h3 class="hm-theme-section__label">{{ 'project.theme.customizer.section.colors'|trans }}</h3>
        <div class="hm-theme-color-grid">
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.bg'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-bg"
                    value="{{ cur_bg|length == 7 and cur_bg starts with '#' ? cur_bg : '#0c0c14' }}"
                >
            </label>
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.ink'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-ink"
                    value="{{ cur_ink|length == 7 and cur_ink starts with '#' ? cur_ink : '#e8e4ff' }}"
                >
            </label>
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.accent_primary'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-accent-primary"
                    value="{{ cur_accent_primary|length == 7 and cur_accent_primary starts with '#' ? cur_accent_primary : '#7c3aed' }}"
                >
            </label>
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.accent_secondary'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-accent-secondary"
                    value="{{ cur_accent_secondary|length == 7 and cur_accent_secondary starts with '#' ? cur_accent_secondary : '#10b981' }}"
                >
            </label>
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.slide_bg'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-slide-bg"
                    value="{{ cur_slide_bg|length == 7 and cur_slide_bg starts with '#' ? cur_slide_bg : '#0c0c14' }}"
                >
            </label>
            <label class="hm-theme-color-field">
                <span class="hm-theme-color-field__label">{{ 'project.theme.token.slide_fg'|trans }}</span>
                <input
                    class="hm-theme-color-input"
                    type="color"
                    data-token="--hm-slide-fg"
                    value="{{ cur_slide_fg|length == 7 and cur_slide_fg starts with '#' ? cur_slide_fg : '#e8e4ff' }}"
                >
            </label>
        </div>
    </div>

    {# ── T187 — Typography ────────────────────────────────────────────────── #}
    <div class="hm-theme-section">
        <h3 class="hm-theme-section__label">{{ 'project.theme.customizer.section.typography'|trans }}</h3>
        <div class="hm-theme-typo-grid">
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.font_body'|trans }}</span>
                <select class="hm-theme-select" data-token="--hm-font-body">
                    <option value='"Inter", "Segoe UI", system-ui, sans-serif'{{ cur_font_body == '"Inter", "Segoe UI", system-ui, sans-serif' ? ' selected' }}>Inter (sans-serif)</option>
                    <option value='Georgia, "Times New Roman", serif'{{ cur_font_body == 'Georgia, "Times New Roman", serif' ? ' selected' }}>Georgia (serif)</option>
                    <option value='"Helvetica Neue", Arial, sans-serif'{{ cur_font_body == '"Helvetica Neue", Arial, sans-serif' ? ' selected' }}>Helvetica (sans-serif)</option>
                    <option value='"JetBrains Mono", "Fira Code", monospace'{{ cur_font_body == '"JetBrains Mono", "Fira Code", monospace' ? ' selected' }}>Mono</option>
                </select>
            </label>
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.font_title'|trans }}</span>
                <select class="hm-theme-select" data-token="--hm-font-title">
                    <option value='Georgia, "Times New Roman", serif'{{ cur_font_title == 'Georgia, "Times New Roman", serif' ? ' selected' }}>Georgia (serif)</option>
                    <option value='"Inter", "Segoe UI", system-ui, sans-serif'{{ cur_font_title == '"Inter", "Segoe UI", system-ui, sans-serif' ? ' selected' }}>Inter (sans-serif)</option>
                    <option value='"Helvetica Neue", Arial, sans-serif'{{ cur_font_title == '"Helvetica Neue", Arial, sans-serif' ? ' selected' }}>Helvetica (sans-serif)</option>
                    <option value='"JetBrains Mono", "Fira Code", monospace'{{ cur_font_title == '"JetBrains Mono", "Fira Code", monospace' ? ' selected' }}>Mono</option>
                </select>
            </label>
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.font_weight_bold'|trans }}</span>
                <select class="hm-theme-select" data-token="--hm-font-weight-bold">
                    <option value="400"{{ cur_font_weight_bold == '400' ? ' selected' }}>400 — Normal</option>
                    <option value="500"{{ cur_font_weight_bold == '500' ? ' selected' }}>500 — Medium</option>
                    <option value="600"{{ cur_font_weight_bold == '600' ? ' selected' }}>600 — Semi-bold</option>
                    <option value="700"{{ cur_font_weight_bold == '700' ? ' selected' }}>700 — Bold</option>
                </select>
            </label>
        </div>
    </div>

    {# ── T188 — Density controls ──────────────────────────────────────────── #}
    <div class="hm-theme-section">
        <h3 class="hm-theme-section__label">{{ 'project.theme.customizer.section.density'|trans }}</h3>
        <div class="hm-theme-typo-grid">
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.font_size_title'|trans }}</span>
                <select class="hm-theme-select" data-token="--hm-font-size-title">
                    <option value="clamp(1.8rem, 3.5vw, 3rem)"{{ cur_fs_title == 'clamp(1.8rem, 3.5vw, 3rem)' ? ' selected' }}>{{ 'project.theme.token.size.small'|trans }}</option>
                    <option value="clamp(2.4rem, 5vw, 4.2rem)"{{ cur_fs_title == 'clamp(2.4rem, 5vw, 4.2rem)' ? ' selected' }}>{{ 'project.theme.token.size.medium'|trans }}</option>
                    <option value="clamp(3rem, 6vw, 5rem)"{{ cur_fs_title == 'clamp(3rem, 6vw, 5rem)' ? ' selected' }}>{{ 'project.theme.token.size.large'|trans }}</option>
                </select>
            </label>
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.font_size_subtitle'|trans }}</span>
                <select class="hm-theme-select" data-token="--hm-font-size-subtitle">
                    <option value="0.95rem"{{ cur_fs_subtitle == '0.95rem' ? ' selected' }}>{{ 'project.theme.token.size.small'|trans }}</option>
                    <option value="1.05rem"{{ cur_fs_subtitle == '1.05rem' ? ' selected' }}>{{ 'project.theme.token.size.medium_small'|trans }}</option>
                    <option value="1.2rem"{{ cur_fs_subtitle == '1.2rem' ? ' selected' }}>{{ 'project.theme.token.size.medium'|trans }}</option>
                    <option value="1.4rem"{{ cur_fs_subtitle == '1.4rem' ? ' selected' }}>{{ 'project.theme.token.size.large'|trans }}</option>
                </select>
            </label>
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.letter_spacing_label'|trans }}</span>
                <input
                    class="hm-theme-spacing-input"
                    type="range"
                    data-token="--hm-letter-spacing-label"
                    data-unit="em"
                    min="0.00"
                    max="0.30"
                    step="0.01"
                    value="{{ cur_ls_label|replace({'em': ''}) }}"
                >
                <span class="hm-theme-spacing-display" data-spacing-display>{{ cur_ls_label }}</span>
            </label>
            <label class="hm-theme-select-field">
                <span class="hm-theme-select-field__label">{{ 'project.theme.token.letter_spacing_tight'|trans }}</span>
                <input
                    class="hm-theme-spacing-input"
                    type="range"
                    data-token="--hm-letter-spacing-tight"
                    data-unit="em"
                    min="-0.05"
                    max="0.10"
                    step="0.01"
                    value="{{ cur_ls_tight|replace({'em': ''}) }}"
                >
                <span class="hm-theme-spacing-display" data-spacing-display>{{ cur_ls_tight }}</span>
            </label>
        </div>
    </div>

    {# ── Error / status ───────────────────────────────────────────────────── #}
    <div class="hm-alert hm-alert--danger" data-theme-error hidden></div>

    {# ── Save button ──────────────────────────────────────────────────────── #}
    <div class="hm-theme-customizer__actions">
        <button
            class="hm-button"
            type="button"
            data-theme-save
        >{{ 'project.theme.tokens.save'|trans }}</button>
    </div>
</section>

<style>
    .hm-theme-customizer {
        padding: 24px;
        border-radius: 26px;
        border: 1px solid rgba(124, 58, 237, 0.10);
        background: var(--hm-surface);
    }

    .hm-theme-customizer__header {
        margin-bottom: 20px;
    }

    .hm-theme-customizer__title {
        margin: 10px 0 6px;
        font-family: var(--hm-font-title);
        font-size: clamp(1.4rem, 2vw, 1.8rem);
    }

    .hm-theme-customizer__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        margin-top: 20px;
    }

    .hm-theme-section {
        margin-bottom: 24px;
    }

    .hm-theme-section__label {
        margin: 0 0 12px;
        font-size: 0.88rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.10em;
        color: var(--hm-ink-soft);
    }

    /* T186 — Light/dark mode toggle */
    .hm-theme-mode-toggle {
        display: inline-flex;
        gap: 8px;
        padding: 4px;
        border-radius: 14px;
        background: var(--hm-surface-strong);
        border: 1px solid var(--hm-border);
    }

    .hm-theme-mode-btn {
        padding: 8px 18px;
        border: none;
        border-radius: 10px;
        font: inherit;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        color: var(--hm-ink-soft);
        background: transparent;
        transition: background 0.15s ease, color 0.15s ease;
    }

    .hm-theme-mode-btn:hover,
    .hm-theme-mode-btn--active {
        background: var(--hm-accent-soft);
        color: var(--hm-accent-primary);
    }

    /* T185 — Color pickers */
    .hm-theme-color-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 12px;
    }

    .hm-theme-color-field {
        display: grid;
        gap: 6px;
    }

    .hm-theme-color-field__label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--hm-ink-soft);
    }

    .hm-theme-color-input {
        width: 100%;
        height: 40px;
        border: 1px solid var(--hm-border);
        border-radius: 10px;
        padding: 2px 4px;
        cursor: pointer;
        background: var(--hm-surface-strong);
    }

    /* T187 — Typography selects / T188 — Density controls */
    .hm-theme-typo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 14px;
    }

    .hm-theme-select-field {
        display: grid;
        gap: 6px;
    }

    .hm-theme-select-field__label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--hm-ink-soft);
    }

    .hm-theme-select {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--hm-border);
        border-radius: 12px;
        background: var(--hm-surface-strong);
        color: var(--hm-ink);
        font: inherit;
        font-size: 0.9rem;
        cursor: pointer;
    }

    .hm-theme-select:focus {
        outline: none;
        border-color: var(--hm-accent-primary);
        box-shadow: 0 0 0 3px var(--hm-accent-soft);
    }

    .hm-theme-spacing-input {
        width: 100%;
        accent-color: var(--hm-accent-primary);
        cursor: pointer;
    }

    .hm-theme-spacing-display {
        font-size: 0.80rem;
        color: var(--hm-ink-soft);
        font-variant-numeric: tabular-nums;
    }
</style>

<script>
    (() => {
        const customizer = document.querySelector('[data-theme-customizer]');
        if (!customizer) return;

        const saveUrl      = customizer.dataset.saveUrl;
        const csrfToken    = customizer.dataset.csrfToken;
        const errorBox     = customizer.querySelector('[data-theme-error]');
        const saveBtn      = customizer.querySelector('[data-theme-save]');
        const labelSaving  = customizer.dataset.labelSaving  || 'Sauvegarde…';
        const labelSave    = customizer.dataset.labelSave    || 'Appliquer les personnalisations';
        const errorGeneric = customizer.dataset.errorGeneric || 'Une erreur est survenue.';

        // T189 — real-time preview: apply a CSS custom property immediately
        const applyToken = (token, value) => {
            document.documentElement.style.setProperty(token, value);
        };

        // T186 — Light/dark mode buttons
        customizer.querySelectorAll('[data-theme-mode]').forEach((btn) => {
            btn.addEventListener('click', () => {
                const bg      = btn.dataset.modeBg;
                const ink     = btn.dataset.modeInk;
                const slideBg = btn.dataset.modeSlideBg;
                const slideFg = btn.dataset.modeSlideFg;

                // Update color picker inputs so saved values are consistent
                const map = {
                    '--hm-bg': bg,
                    '--hm-ink': ink,
                    '--hm-slide-bg': slideBg,
                    '--hm-slide-fg': slideFg,
                };

                Object.entries(map).forEach(([token, value]) => {
                    const input = customizer.querySelector(`[data-token="${token}"]`);
                    if (input) {
                        input.value = value;
                    }
                    applyToken(token, value);
                });

                // Visual active state
                customizer.querySelectorAll('[data-theme-mode]').forEach((b) => b.classList.remove('hm-theme-mode-btn--active'));
                btn.classList.add('hm-theme-mode-btn--active');
            });
        });

        // T189 — Color inputs: preview on change
        customizer.querySelectorAll('.hm-theme-color-input').forEach((input) => {
            input.addEventListener('input', () => {
                applyToken(input.dataset.token, input.value);
            });
        });

        // T189 — Select inputs: preview on change
        customizer.querySelectorAll('.hm-theme-select').forEach((select) => {
            select.addEventListener('change', () => {
                applyToken(select.dataset.token, select.value);
            });
        });

        // Helper: format a range value with its CSS unit
        const rangeValue = (range) => parseFloat(range.value).toFixed(2) + (range.dataset.unit || '');

        // T188 / T189 — Range inputs: preview on input + update display label
        customizer.querySelectorAll('.hm-theme-spacing-input').forEach((range) => {
            const display = range.nextElementSibling;

            const update = () => {
                const val = rangeValue(range);
                applyToken(range.dataset.token, val);
                if (display) {
                    display.textContent = val;
                }
            };

            range.addEventListener('input', update);
        });

        // T190 — Collect all current control values and POST to the server
        const collectTokens = () => {
            const tokens = {};

            customizer.querySelectorAll('[data-token]').forEach((el) => {
                const token = el.dataset.token;
                if (!token) return;

                if (el.tagName === 'INPUT' && el.type === 'range') {
                    tokens[token] = rangeValue(el);
                } else {
                    tokens[token] = el.value;
                }
            });

            return tokens;
        };

        saveBtn.addEventListener('click', async () => {
            errorBox.hidden = true;
            errorBox.textContent = '';
            saveBtn.disabled = true;
            saveBtn.textContent = labelSaving;

            try {
                const tokens = collectTokens();
                const formData = new FormData();
                formData.set('_token', csrfToken);
                Object.entries(tokens).forEach(([k, v]) => {
                    formData.append(`tokens[${k}]`, v);
                });

                const response = await fetch(saveUrl, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                });

                const data = await response.json();
                if (!response.ok) {
                    throw data;
                }
            } catch (err) {
                errorBox.textContent = (err && err.message) || errorGeneric;
                errorBox.hidden = false;
            } finally {
                saveBtn.disabled = false;
                saveBtn.textContent = labelSave;
            }
        });
    })();
</script>
{% endif %}
