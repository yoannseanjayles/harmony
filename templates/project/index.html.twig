{% extends 'base.html.twig' %}

{% block title %}{{ 'project.index.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hm-dashboard--wide {
            width: min(100%, 1200px);
        }

        .hm-summary-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

        .hm-summary-card,
        .hm-project-card {
            padding: 18px;
            border-radius: 14px;
            background: var(--hm-surface-strong);
            border: 1px solid var(--hm-border);
            transition: border-color 0.2s, transform 0.2s;
        }

        .hm-summary-card:hover {
            border-color: rgba(139, 92, 246, 0.16);
            transform: translateY(-1px);
        }

        .hm-summary-card span,
        .hm-project-card__label,
        .hm-project-stat span {
            display: block;
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            color: var(--hm-ink-soft);
        }

        .hm-summary-card strong,
        .hm-project-stat strong {
            display: block;
            margin-top: 8px;
            font-size: 1.5rem;
            font-family: var(--hm-font-title);
            font-weight: 700;
        }

        .hm-toolbar {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-end;
            margin: 18px 0 14px;
        }

        .hm-toolbar-form {
            display: grid;
            grid-template-columns: minmax(200px, 1.7fr) repeat(2, minmax(130px, 0.7fr)) auto auto;
            gap: 10px;
            width: 100%;
            align-items: end;
        }

        .hm-toolbar-field {
            display: grid;
            gap: 6px;
        }

        .hm-toolbar-field label {
            font-weight: 600;
            font-size: 0.8rem;
            color: var(--hm-ink-soft);
        }

        .hm-toolbar-field input,
        .hm-toolbar-field select {
            width: 100%;
            min-height: 44px;
            padding: 0 14px;
            border-radius: 10px;
            border: 1px solid var(--hm-border);
            background: rgba(255, 255, 255, 0.03);
            color: var(--hm-ink);
            font: inherit;
            font-size: 0.9rem;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

        .hm-toolbar-field input:focus,
        .hm-toolbar-field select:focus {
            outline: none;
            border-color: var(--hm-accent-primary);
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.10);
        }

        .hm-filter-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-bottom: 8px;
        }

        .hm-results-copy {
            margin: 0 0 12px;
            color: var(--hm-ink-soft);
        }

        .hm-project-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 14px;
        }

        .hm-project-card {
            display: grid;
            gap: 14px;
        }

        .hm-project-card:hover {
            border-color: rgba(139, 92, 246, 0.18);
            transform: translateY(-2px);
        }

        .hm-project-card__top {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-start;
        }

        .hm-project-card__title {
            margin: 8px 0 0;
            font-family: var(--hm-font-title);
            font-size: 1.5rem;
            font-weight: 600;
            line-height: 1.1;
        }

        .hm-project-card__updated {
            margin: -4px 0 0;
            color: var(--hm-ink-soft);
        }

        .hm-status {
            display: inline-flex;
            align-items: center;
            min-height: 30px;
            padding: 0 10px;
            border-radius: 999px;
            font-size: 0.76rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .hm-status--active {
            background: rgba(29, 122, 90, 0.12);
            color: var(--hm-success);
        }

        .hm-status--draft {
            background: rgba(191, 106, 61, 0.12);
            color: var(--hm-accent-deep);
        }

        .hm-status--archived {
            background: rgba(23, 63, 53, 0.1);
            color: var(--hm-ink);
        }

        .hm-project-stats {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .hm-project-stat {
            padding: 14px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--hm-border);
        }

        .hm-export-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .hm-export-card {
            padding: 14px;
            border-radius: 12px;
            border: 1px solid var(--hm-border);
            background: rgba(255, 255, 255, 0.02);
        }

        .hm-export-card__meta {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            margin-bottom: 12px;
        }

        .hm-export-card__rate {
            font-weight: 700;
            color: var(--hm-ink-soft);
        }

        .hm-meter {
            height: 6px;
            overflow: hidden;
            border-radius: 999px;
            background: rgba(139, 92, 246, 0.08);
        }

        .hm-meter__fill {
            height: 100%;
            border-radius: 999px;
            background: rgba(139, 92, 246, 0.25);
        }

        .hm-meter__fill--success {
            background: linear-gradient(135deg, #34d399, #10b981);
        }

        .hm-meter__fill--warning {
            background: linear-gradient(135deg, #f59e0b, #d97706);
        }

        .hm-meter__fill--danger {
            background: linear-gradient(135deg, #f87171, #ef4444);
        }

        .hm-meter__fill--idle {
            background: rgba(139, 92, 246, 0.14);
        }

        .hm-pagination {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            margin-top: 14px;
        }

        @media (max-width: 1100px) {
            .hm-summary-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }

            .hm-toolbar-form {
                grid-template-columns: 1fr 1fr;
                grid-template-areas:
                    "search search"
                    "sort   direction"
                    "submit reset";
            }

            .hm-toolbar-form > *:nth-child(1) { grid-area: search; }
            .hm-toolbar-form > *:nth-child(2) { grid-area: sort; }
            .hm-toolbar-form > *:nth-child(3) { grid-area: direction; }
            .hm-toolbar-form > *:nth-child(4) { grid-area: submit; }
            .hm-toolbar-form > *:nth-child(5) { grid-area: reset; }
        }

        @media (max-width: 768px) {
            .hm-summary-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 900px) {
            .hm-project-stats,
            .hm-export-grid {
                grid-template-columns: 1fr;
            }

            .hm-project-card__top,
            .hm-pagination {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @media (max-width: 600px) {
            .hm-toolbar-form {
                grid-template-columns: 1fr;
                grid-template-areas:
                    "search"
                    "sort"
                    "direction"
                    "submit"
                    "reset";
            }

            .hm-summary-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
    {% set baseQuery = {
        scope: currentScope,
        search: currentSearch,
        sort: currentSort,
        direction: currentDirection
    } %}

    <main class="hm-shell hm-shell--top">
        <section class="hm-dashboard hm-dashboard--wide">
            <header>
                <div>
                    <span class="hm-badge">{{ 'project.index.badge'|trans }}</span>
                    <h1 class="hm-page-title">{{ 'project.index.title'|trans }}</h1>
                    <p class="hm-copy">{{ 'project.index.subtitle'|trans }}</p>
                </div>

                <div class="hm-actions">
                    <a class="hm-link" href="{{ path('app_dashboard') }}">{{ 'project.back_dashboard'|trans }}</a>
                    <a class="hm-button" href="{{ path('app_project_new') }}">{{ 'project.index.cta'|trans }}</a>
                </div>
            </header>

            {% for flash in app.flashes('success') %}
                <div class="hm-alert hm-alert--success">{{ flash|trans }}</div>
            {% endfor %}

            <section class="hm-summary-grid">
                <article class="hm-summary-card">
                    <span>{{ 'project.index.summary.projects'|trans }}</span>
                    <strong>{{ summary.visibleProjects }}</strong>
                </article>
                <article class="hm-summary-card">
                    <span>{{ 'project.index.summary.slides'|trans }}</span>
                    <strong>{{ summary.totalSlides }}</strong>
                </article>
                <article class="hm-summary-card">
                    <span>{{ 'project.index.summary.ai_cost'|trans }}</span>
                    <strong>{{ summary.totalAiCostUsd|number_format(2, ',', ' ') }} USD</strong>
                </article>
                <article class="hm-summary-card">
                    <span>{{ 'project.index.summary.export_html'|trans }}</span>
                    <strong>{{ summary.htmlExports.rate|number_format(0, ',', ' ') }} %</strong>
                </article>
                <article class="hm-summary-card">
                    <span>{{ 'project.index.summary.export_pdf'|trans }}</span>
                    <strong>{{ summary.pdfExports.rate|number_format(0, ',', ' ') }} %</strong>
                </article>
            </section>

            <div class="hm-filter-tabs">
                {% set scopeLinks = {
                    active: 'project.index.filter.active',
                    archived: 'project.index.filter.archived',
                    all: 'project.index.filter.all'
                } %}
                {% for scopeValue, labelKey in scopeLinks %}
                    <a class="{{ currentScope == scopeValue ? 'hm-button' : 'hm-link' }}" href="{{ path('app_project_index', baseQuery|merge({ scope: scopeValue, page: 1 })) }}">{{ labelKey|trans }}</a>
                {% endfor %}
            </div>

            <div class="hm-toolbar">
                <form class="hm-toolbar-form" method="get" action="{{ path('app_project_index') }}">
                    <input type="hidden" name="scope" value="{{ currentScope }}">
                    <div class="hm-toolbar-field">
                        <label for="project-search">{{ 'project.index.search_label'|trans }}</label>
                        <input id="project-search" type="search" name="search" value="{{ currentSearch }}" placeholder="{{ 'project.index.search_placeholder'|trans }}">
                    </div>
                    <div class="hm-toolbar-field">
                        <label for="project-sort">{{ 'project.index.sort_label'|trans }}</label>
                        <select id="project-sort" name="sort">
                            {% for sortValue, labelKey in sortOptions %}
                                <option value="{{ sortValue }}" {{ currentSort == sortValue ? 'selected' }}>{{ labelKey|trans }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="hm-toolbar-field">
                        <label for="project-direction">{{ 'project.index.direction_label'|trans }}</label>
                        <select id="project-direction" name="direction">
                            {% for directionValue, labelKey in directionOptions %}
                                <option value="{{ directionValue }}" {{ currentDirection == directionValue ? 'selected' }}>{{ labelKey|trans }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <button class="hm-button" type="submit">{{ 'project.index.apply_filters'|trans }}</button>
                    <a class="hm-link" href="{{ path('app_project_index', { scope: currentScope }) }}">{{ 'project.index.reset_filters'|trans }}</a>
                </form>
            </div>

            <p class="hm-results-copy">{{ 'project.index.results'|trans({ '%count%': totalProjects }) }}</p>

            {% if dashboardEntries is empty %}
                <div class="hm-summary-card">
                    <strong>
                        {% if currentSearch is not empty %}
                            {{ 'project.index.empty_filtered_title'|trans }}
                        {% elseif currentScope == 'archived' %}
                            {{ 'project.index.empty_archived_title'|trans }}
                        {% else %}
                            {{ 'project.index.empty_title'|trans }}
                        {% endif %}
                    </strong>
                    <p class="hm-muted">
                        {% if currentSearch is not empty %}
                            {{ 'project.index.empty_filtered_copy'|trans }}
                        {% elseif currentScope == 'archived' %}
                            {{ 'project.index.empty_archived_copy'|trans }}
                        {% else %}
                            {{ 'project.index.empty_copy'|trans }}
                        {% endif %}
                    </p>
                </div>
            {% else %}
                <section class="hm-project-grid">
                    {% for entry in dashboardEntries %}
                        {% set project = entry.project %}
                        {% set statusClass = project.isArchived
                            ? 'hm-status--archived'
                            : (project.status == 'active' ? 'hm-status--active' : 'hm-status--draft') %}
                        {% set htmlTone = entry.htmlExports.total == 0
                            ? 'idle'
                            : (entry.htmlExports.rate >= 80 ? 'success' : (entry.htmlExports.rate >= 50 ? 'warning' : 'danger')) %}
                        {% set pdfTone = entry.pdfExports.total == 0
                            ? 'idle'
                            : (entry.pdfExports.rate >= 80 ? 'success' : (entry.pdfExports.rate >= 50 ? 'warning' : 'danger')) %}

                        <article class="hm-project-card" data-project-card>
                            <div class="hm-project-card__top">
                                <div>
                                    <span class="hm-badge">{{ project.isArchived ? 'project.archived.badge'|trans : 'project.card.scope_active'|trans }}</span>
                                    <h2 class="hm-project-card__title" data-project-title>{{ project.title }}</h2>
                                </div>
                                <span class="hm-status {{ statusClass }}">{{ ('project.status.' ~ project.status)|trans }}</span>
                            </div>

                            <p class="hm-muted">{{ 'project.card.meta'|trans({
                                '%provider%': project.providerLabelKey|trans,
                                '%model%': project.modelLabelKey|trans,
                                '%status%': ('project.status.' ~ project.status)|trans
                            }) }}</p>
                            <p class="hm-project-card__updated">{{ 'project.card.updated_at'|trans({ '%date%': project.updatedAt|date('d/m/Y H:i') }) }}</p>

                            <section class="hm-project-stats">
                                <article class="hm-project-stat">
                                    <span>{{ 'project.show.card.slides'|trans }}</span>
                                    <strong>{{ project.slidesCount }}</strong>
                                </article>
                                <article class="hm-project-stat">
                                    <span>{{ 'project.card.ai_cost'|trans }}</span>
                                    <strong>{{ entry.aiCostUsd|number_format(2, ',', ' ') }} USD</strong>
                                </article>
                            </section>

                            <section class="hm-export-grid">
                                <article class="hm-export-card">
                                    <div class="hm-export-card__meta">
                                        <div>
                                            <span class="hm-project-card__label">{{ 'project.card.export_html'|trans }}</span>
                                            <strong class="hm-export-card__rate">
                                                {% if entry.htmlExports.total > 0 %}
                                                    {{ entry.htmlExports.successes }}/{{ entry.htmlExports.total }} | {{ entry.htmlExports.rate|number_format(0, ',', ' ') }} %
                                                {% else %}
                                                    {{ 'project.card.export_empty'|trans }}
                                                {% endif %}
                                            </strong>
                                        </div>
                                    </div>
                                    <div class="hm-meter">
                                        <div class="hm-meter__fill hm-meter__fill--{{ htmlTone }}" style="width: {{ entry.htmlExports.total > 0 ? entry.htmlExports.rate : 8 }}%"></div>
                                    </div>
                                </article>
                                <article class="hm-export-card">
                                    <div class="hm-export-card__meta">
                                        <div>
                                            <span class="hm-project-card__label">{{ 'project.card.export_pdf'|trans }}</span>
                                            <strong class="hm-export-card__rate">
                                                {% if entry.pdfExports.total > 0 %}
                                                    {{ entry.pdfExports.successes }}/{{ entry.pdfExports.total }} | {{ entry.pdfExports.rate|number_format(0, ',', ' ') }} %
                                                {% else %}
                                                    {{ 'project.card.export_empty'|trans }}
                                                {% endif %}
                                            </strong>
                                        </div>
                                    </div>
                                    <div class="hm-meter">
                                        <div class="hm-meter__fill hm-meter__fill--{{ pdfTone }}" style="width: {{ entry.pdfExports.total > 0 ? entry.pdfExports.rate : 8 }}%"></div>
                                    </div>
                                </article>
                            </section>

                            <div class="hm-actions">
                                <a class="hm-link" href="{{ path('app_project_show', { id: project.id }) }}">{{ 'project.card.show'|trans }}</a>
                                <a class="hm-link" href="{{ path('app_project_versions', { id: project.id }) }}">{{ 'project.card.history'|trans }}</a>
                                {% if not project.isArchived %}
                                    <a class="hm-link" href="{{ path('app_project_edit', { id: project.id }) }}">{{ 'project.card.edit'|trans }}</a>
                                {% endif %}
                                <form class="hm-inline-form" method="post" action="{{ path('app_project_duplicate', { id: project.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('duplicate_project_' ~ project.id) }}">
                                    <button class="hm-link" type="submit">{{ 'project.card.duplicate'|trans }}</button>
                                </form>
                                {% if project.isArchived %}
                                    <form class="hm-inline-form" method="post" action="{{ path('app_project_restore', { id: project.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('restore_project_' ~ project.id) }}">
                                        <button class="hm-link" type="submit">{{ 'project.card.restore'|trans }}</button>
                                    </form>
                                {% else %}
                                    <form class="hm-inline-form" method="post" action="{{ path('app_project_archive', { id: project.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('archive_project_' ~ project.id) }}">
                                        <button class="hm-link" type="submit">{{ 'project.card.archive'|trans }}</button>
                                    </form>
                                {% endif %}
                            </div>
                        </article>
                    {% endfor %}
                </section>

                <nav class="hm-pagination" aria-label="{{ 'project.index.pagination.aria'|trans }}">
                    <div class="hm-actions">
                        {% if hasPreviousPage %}
                            <a class="hm-link" href="{{ path('app_project_index', baseQuery|merge({ page: currentPage - 1 })) }}">{{ 'project.index.pagination.previous'|trans }}</a>
                        {% endif %}
                        {% if hasNextPage %}
                            <a class="hm-link" href="{{ path('app_project_index', baseQuery|merge({ page: currentPage + 1 })) }}">{{ 'project.index.pagination.next'|trans }}</a>
                        {% endif %}
                    </div>
                    <span class="hm-muted">{{ 'project.index.pagination.summary'|trans({ '%page%': currentPage, '%pages%': totalPages }) }}</span>
                </nav>
            {% endif %}
        </section>
    </main>
{% endblock %}
