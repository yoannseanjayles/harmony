{% extends 'base.html.twig' %}

{% block title %}{{ 'project.edit.meta_title'|trans({ '%title%': project.title }) }}{% endblock %}

{% block body %}
    <main class="hm-shell">
        <section class="hm-card">
            <aside class="hm-panel hm-panel--brand">
                <span class="hm-kicker">{{ 'project.edit.badge'|trans }}</span>
                <h1 class="hm-brand-title">{{ project.title }}</h1>
                <p>{{ 'project.edit.copy'|trans }}</p>
            </aside>

            <section class="hm-panel hm-form-wrap">
                <h2 class="hm-page-title">{{ 'project.edit.form_title'|trans }}</h2>
                <p class="hm-copy">{{ 'project.edit.subtitle'|trans }}</p>
                {% include 'project/_form.html.twig' with { submit_label: 'project.edit.submit' } %}
            </section>
        </section>
    </main>
{% endblock %}
